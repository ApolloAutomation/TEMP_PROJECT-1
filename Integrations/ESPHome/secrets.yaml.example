# Copy this file to secrets.yaml (same directory) and fill in your values.
# secrets.yaml is gitignored — never commit real broker addresses or credentials.

# MQTT broker connection (used by TEMP_PRO-1_MQTT.yaml and TEMP_PRO-1_MQTT_ETH.yaml)
mqtt_broker: "192.168.1.10"
mqtt_port: 1883
mqtt_username: ""
mqtt_password: ""

# Web UI basic auth (used by Core_MQTT.yaml and TEMP_PRO-1_W_BATTERY.yaml).
# Per-device overrides set at commissioning time take precedence over these
# compile-time defaults (see the Web Auth Username / Password entities).
web_auth_username: "admin"
web_auth_password: "change-me"
